{
  "name": "@local/pi-extensions",
  "version": "0.0.1",
  "description": "Vendored extensions from mitsuhiko/agent-stuff",
  "type": "module",
  "private": true,
  "keywords": ["pi-package"],
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch"
  },
  "pi": {
    "extensions": ["./dist"],
    "build": {
      "srcDir": "./src",
      "outDir": "./dist",
      "target": "bun"
    }
  },
  "exports": {
    "./shared/*": "./src/shared/*.ts"
  },
	"dependencies": {
		"@local/pi-dashboard": "workspace:*",
		"@local/pi-subagents": "workspace:*",
		"@local/pi-logger": "workspace:*",
		"diff": "^8.0.2"
	},
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "^0.79.2",
    "typebox": "*"
  }
}
