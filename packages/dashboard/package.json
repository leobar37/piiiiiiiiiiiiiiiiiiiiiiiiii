{
  "name": "@local/pi-dashboard",
  "version": "0.74.0",
  "description": "Web dashboard for Pi sessions",
  "type": "module",
  "main": "electron/dist/main.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "build:frontend": "cd frontend && bun run build",
    "build:all": "bun run build && bun run build:frontend",
    "build:electron": "vite build -c electron/vite.config.ts",
    "electron:start": "electron electron/dist/main.cjs",
    "electron:dev": "bun run scripts/electron-dev.ts",
    "electron:build": "bun run build:all && (cd ../extensions && bun run build) && (cd ../coding-agent && bun run build:binary) && bun run build:electron",
    "electron:pack": "bun run electron:build && electron-builder",
    "test": "vitest --run"
  },
  "dependencies": {
    "@orpc/server": "^1.14.3",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "^0.79.2"
  },
  "build": {
    "appId": "works.earendil.pi-dashboard",
    "productName": "Pi Dashboard",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "frontend/dist/**/*",
      "electron/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../coding-agent/dist/pi",
        "to": "pi"
      },
      {
        "from": "../extensions/dist",
        "to": "extensions"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
