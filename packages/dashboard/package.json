{
  "name": "@earendil-works/pi-web",
  "version": "0.74.0",
  "description": "Web dashboard for Pi sessions",
  "type": "module",
  "bin": {
    "pi-web": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "build:frontend": "cd frontend && bun run build",
    "build:all": "bun run build && bun run build:frontend",
    "test": "vitest --run"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "workspace:*",
    "@orpc/server": "^1.14.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*"
  }
}
