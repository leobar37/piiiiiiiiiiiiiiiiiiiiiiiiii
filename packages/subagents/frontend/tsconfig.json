{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"baseUrl": ".",
		"types": ["vite/client"],
		"paths": {
			"@subagents/contract": ["../src/api/contract.ts"]
		}
	},
	"include": ["src", "../src/api"]
}
